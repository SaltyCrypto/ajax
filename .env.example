# ===========================================
# AJAX — YouTube Astrology
# Copy this file to .env.local and fill in values
# ===========================================

# --- Supabase ---
# Get these from: https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Google / YouTube ---
# Get these from: https://console.cloud.google.com → APIs & Services → Credentials
# 1. Create OAuth 2.0 Client ID (Web application)
# 2. Add authorized redirect URI: http://localhost:3000/api/auth/youtube/callback
# 3. Enable YouTube Data API v3 in the API Library
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Spotify ---
# Get these from: https://developer.spotify.com/dashboard → Create App
# 1. Set redirect URI: http://localhost:3000/api/auth/spotify/callback
# 2. Select "Web API" as the API to use
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Optional: AI-generated descriptions ---
# Used for generating the one-liner on DNA cards
# If not set, falls back to template-based descriptions
ANTHROPIC_API_KEY=your-anthropic-api-key
